# Flutter Android UI Bug Hunter — 运行参数
# 修改这里的值即可，无需改动代码
# 关键词请编辑 keywords/ 目录下的 CSV 文件
# 黑名单请编辑 blacklist.csv

# 目标平台: android | ios | all
PLATFORM=android

# 最少 open issues 数量（低于此值的仓库直接跳过）
MIN_ISSUES=50

# 最终输出的仓库数量
LIMIT=10

# GitHub 搜索的候选仓库总量（越大越慢但覆盖更全）
CANDIDATES=140

# issues 分页上限（每页 100 条）
MAX_ISSUE_PAGES=3

# releases 分页上限（每页 30 条）
MAX_RELEASE_PAGES=2

# 输出格式: md | json | text
OUTPUT_FORMAT=md

# Markdown 报告保存路径（留空 = 脚本同目录下 flutter-bug-report.md）
MD_OUTPUT=
